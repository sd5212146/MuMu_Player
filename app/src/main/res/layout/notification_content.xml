<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- 左边：封面 -->
    <ImageView
        android:id="@+id/notification_album_art"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:importantForAccessibility="no" />

    <!-- 右边：上层进度 + 下层控制 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:orientation="vertical">

        <!-- 上层：歌名 + 歌手 + 进度条 -->
        <TextView
            android:id="@+id/notification_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:singleLine="true" />

        <TextView
            android:id="@+id/notification_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#661A1A1A"
            android:singleLine="true" />

        <ProgressBar
            android:id="@+id/notification_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:max="1000"
            android:progressTint="#1565C0" />

        <!-- 下层：控制按钮（播放模式、上一曲、播放暂停、下一曲、红心） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <ImageButton
                android:id="@+id/notification_btn_play_mode"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_play_mode_shuffle"
                android:background="@null"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:importantForAccessibility="no" />

            <ImageButton
                android:id="@+id/notification_btn_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@null"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:importantForAccessibility="no" />

            <ImageButton
                android:id="@+id/notification_btn_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@null"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:importantForAccessibility="no" />

            <ImageButton
                android:id="@+id/notification_btn_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:background="@null"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:importantForAccessibility="no" />

            <ImageButton
                android:id="@+id/notification_btn_favorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_heart_outline"
                android:background="@null"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:importantForAccessibility="no" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
